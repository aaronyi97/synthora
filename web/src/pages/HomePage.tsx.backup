import { useState, useCallback, useEffect, useRef } from "react";
import { useNavigate } from "react-router-dom";
import { WifiOff, Plus, CheckCircle, Menu } from "lucide-react";
import ReactMarkdown from "react-markdown";
import { api } from "@/api/client";
import type { Mode, AskResponse, ApiError, CompanionHint, ClarificationNeeded } from "@/types";
import QueryInput from "@/components/query/QueryInput";
import ModeSelector from "@/components/query/ModeSelector";
import ResponseDisplay from "@/components/query/ResponseDisplay";
import ConversationSidebar from "@/components/ConversationSidebar";
import { useConversations } from "@/hooks/useConversations";

// Mode label for resolved mode display
const MODE_LABELS: Record<string, string> = {
  light: "Light 快速综合",
  deep: "Deep 深度思考",
  research: "Research 天花板研究",
  auto: "智能",
};

// User-friendly stage names (backend sends technical names like fan_out/synthesis)
const STAGE_LABELS: Record<string, string> = {
  pipeline: "正在启动...",
  search: "正在搜索相关资料...",
  fan_out: "正在收集多方观点...",
  moa_layer2: "正在交叉验证答案...",
  synthesis: "正在综合最优答案...",
  refinement: "正在精炼答案...",
};

function friendlyStage(raw: string): string {
  // raw could be stage name or detail like "Judge: claude_sonnet_thinking"
  // Check if it matches a known stage key first
  const lower = raw.toLowerCase();
  for (const [key, label] of Object.entries(STAGE_LABELS)) {
    if (lower.startsWith(key) || lower.includes(key)) return label;
  }
  // Fallback: if it looks like "N contributors" → use fan_out label
  if (/\d+\s*contributors?/i.test(raw)) return STAGE_LABELS.fan_out;
  if (/judge/i.test(raw)) return STAGE_LABELS.synthesis;
  if (/moa/i.test(raw)) return STAGE_LABELS.moa_layer2;
  return "正在处理...";
}

export default function HomePage() {
  const navigate = useNavigate();
  const [mode, setMode] = useState<Mode>("auto");
  const [webSearch, setWebSearch] = useState(true);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [isSocraticLoading, setIsSocraticLoading] = useState(false);
  const [backendOnline, setBackendOnline] = useState<boolean | null>(null);
  const [sidebarOpen, setSidebarOpen] = useState(true);

  // Multi-conversation management
  const {
    conversations,
    current,
    currentId,
    createConversation,
    deleteConversation,
    switchConversation,
    addMessage,
    updateSession,
    updateLastMessage,
  } = useConversations();

  // Current conversation state (derived from current)
  const currentQuestion = current?.messages[current.messages.length - 1]?.role === 'user' 
    ? current.messages[current.messages.length - 1].content : '';
  const response = current?.messages[current.messages.length - 1]?.response || null;
  const sessionId = current?.sessionId || null;
  const turnCount = current?.turnCount || 0;

  // Streaming state
  const [streamStage, setStreamStage] = useState("");
  const [streamPreview, setStreamPreview] = useState("");
  const [streamTokens, setStreamTokens] = useState("");
  const [contributorsDone, setContributorsDone] = useState(0);
  const streamTokensRef = useRef("");

  // Companion hint (DepthGate + Coach)
  const [companionHint, setCompanionHint] = useState<CompanionHint | null>(null);
  // Clarification needed (Deep/Research preflight)
  const [clarification, setClarification] = useState<ClarificationNeeded | null>(null);

  // AbortController for cancellation
  const abortRef = useRef<AbortController | null>(null);
  // Track last question for preflight re-submission
  const lastQuestionRef = useRef<string>("");
  const scrollRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    api.health()
      .then(() => setBackendOnline(true))
      .catch(() => setBackendOnline(false));
  }, []);

  // Auto-scroll to bottom when new content arrives
  useEffect(() => {
    if (scrollRef.current) {
      scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
    }
  }, [streamTokens, streamPreview, response, error]);

  // Start a new conversation
  const handleNewChat = useCallback(() => {
    createConversation();
    setError(null);
    setCompanionHint(null);
    setClarification(null);
    setStreamStage("");
    setStreamPreview("");
    setStreamTokens("");
    streamTokensRef.current = "";
  }, [createConversation]);

  // P1-Q3: unified stream runner — single source of truth for callbacks
  const runAskStream = useCallback(
    (req: { question: string; mode?: string; skip_preflight?: boolean; web_search?: boolean; session_id?: string }) => {
      const ac = new AbortController();
      abortRef.current = ac;
      setLoading(true);
      setError(null);
      setResponse(null);
      setStreamStage("");
      setStreamPreview("");
      setStreamTokens("");
      setContributorsDone(0);
      setCompanionHint(null);
      setClarification(null);
      streamTokensRef.current = "";

      api.askStream(
        {
          question: req.question,
          mode: req.mode || "auto",
          web_search: req.web_search ?? true,
          skip_preflight: req.skip_preflight ?? false,
          session_id: req.session_id || undefined,
        },
        {
          onCompanionHint: (hint) => { if (!ac.signal.aborted) setCompanionHint(hint); },
          onClarificationNeeded: (data) => {
            if (!ac.signal.aborted) { setClarification(data); setLoading(false); }
          },
          onStageStart: (s, _d) => { if (!ac.signal.aborted) setStreamStage(friendlyStage(s)); },
          onContributor: () => { if (!ac.signal.aborted) setContributorsDone((p) => p + 1); },
          onPreview: (_m, c) => { if (!ac.signal.aborted) setStreamPreview(c); },
          onToken: (t) => {
            if (ac.signal.aborted) return;
            streamTokensRef.current += t;
            setStreamTokens(streamTokensRef.current);
            setStreamPreview("");
          },
          onStageComplete: (s, _d) => { if (!ac.signal.aborted) setStreamStage(friendlyStage(s)); },
          onComplete: (r) => {
            if (ac.signal.aborted) return;
            setLoading(false);
            // Update conversation with response
            if (currentId) {
              updateLastMessage(currentId, { response: r });
              if (r.session_id) {
                updateSession(currentId, r.session_id, (current?.turnCount || 0) + 1);
              }
            }
          },
          onError: (e) => { if (ac.signal.aborted) return; setError(e); setLoading(false); },
        },
        ac.signal,
      ).then(() => {
        if (!ac.signal.aborted) setLoading(false);
      }).catch((e) => {
        if (ac.signal.aborted) return;
        const err = e as ApiError;
        setError(err.detail || "请求失败");
        setLoading(false);
      });
    },
    [],
  );

  const cancelRequest = useCallback(() => {
    if (abortRef.current) {
      abortRef.current.abort();
      abortRef.current = null;
    }
    setLoading(false);
    setIsSocraticLoading(false);
    setStreamStage("");
    setStreamPreview("");
    setStreamTokens("");
    setContributorsDone(0);
    streamTokensRef.current = "";
  }, []);

  const handleAsk = useCallback(
    async (question: string) => {
      // Cancel any previous in-flight request
      }

      if (mode === "socratic") {
        setIsSocraticLoading(true);
        const ac = new AbortController();
        abortRef.current = ac;
        try {
          const startRes = await api.socraticStart(question);
          if (ac.signal.aborted) return;
          navigate(`/socratic/${startRes.session_id}`, {
            state: { startRes, question },
          });
        } catch (e) {
          if (!ac.signal.aborted) {
            const err = e as ApiError;
            setError(err.message || "Socratic 启动失败");
          }
        } finally {
          if (!ac.signal.aborted) setIsSocraticLoading(false);
        }
        return;
      }

      // Add user message to conversation
      addMessage(convId, {
        role: 'user',
        content: question,
        timestamp: Date.now(),
      });

      // Add placeholder assistant message (will be updated with response)
      addMessage(convId, {
        role: 'assistant',
        content: '',
        timestamp: Date.now(),
      });

      lastQuestionRef.current = question;
      runAskStream({
        question,
        mode: mode === "auto" ? "auto" : mode,
        web_search: webSearch,
        session_id: current?.sessionId || undefined,
      });
    },
    [mode, webSearch, currentId, current, createConversation, addMessage, navigate, runAskStream],
  );

  // Handle LOW_CONFIDENCE action buttons from ResponseDisplay
  const handleLowConfidenceAction = useCallback(
    (action: string, question: string) => {
      if (action === "retry_deep" || action === "deep") {
        setMode("deep" as Mode);
        runAskStream({ question, mode: "deep", web_search: webSearch, session_id: sessionId || undefined });
      } else if (action === "retry_research" || action === "research") {
        setMode("research" as Mode);
        runAskStream({ question, mode: "research", web_search: webSearch, session_id: sessionId || undefined });
      } else if (action === "socratic") {
        setMode("socratic" as Mode);
        // Let user click submit — just switch mode
      } else if (action === "rephrase") {
        // No auto-action, user should refine their question
      } else {
        // Unknown action — try to re-ask in deep mode as safe default
        runAskStream({ question, mode: "deep", web_search: webSearch, session_id: sessionId || undefined });
      }
    },
    [webSearch, sessionId, runAskStream],
  );

  // Handle coach hint actions
  const handleCoachAction = useCallback(async (hintType: string, actionMode: string, planId?: string) => {
    if (actionMode === "accept_plan" && planId) {
      try {
        await api.activatePlan(planId);
        setCompanionHint(null);
      } catch { /* ignore */ }
    } else {
      setMode(actionMode as Mode);
      setCompanionHint(null);
    }
  }, []);

  const isStreaming = loading && !isSocraticLoading;
  const isAnyLoading = loading || isSocraticLoading;
  const hasContent = current && current.messages.length > 0;

  // Resolved mode display (when auto was used)
  const resolvedMode = response?.mode && mode === "auto" && response.mode !== "auto"
    ? MODE_LABELS[response.mode] || response.mode
    : null;

  return (
    <div className="flex h-screen bg-gradient-to-br from-surface-1 via-surface-2 to-surface-1">
      {/* Sidebar */}
      {sidebarOpen && (
        <ConversationSidebar
          conversations={conversations}
          currentId={currentId}
          onNew={createConversation}
          onSwitch={switchConversation}
          onDelete={deleteConversation}
          onClose={() => setSidebarOpen(false)}
        />
      )}

      {/* Main content */}
      <div className="flex-1 flex flex-col">
        {/* Backend offline banner */}
        {backendOnline === false && (
          <div className="shrink-0 px-4 py-1 bg-amber-500/10 text-amber-400 text-[11px] flex items-center gap-2 justify-center">
            <WifiOff size={11} />
            <span>后端未连接</span>
          </div>
        )}

        {/* Main content area */}
        <div ref={scrollRef} className="flex-1 overflow-y-auto">
          <div className="max-w-3xl mx-auto px-3 sm:px-4 py-2.5 flex items-center justify-between gap-3 flex-1">
            {/* Empty state — centered placeholder */}
            {!hasContent && (
              <div className="flex items-center justify-center" style={{ minHeight: "calc(100vh - 160px)" }}>
                <div className="text-center text-zinc-600">
                  <div className="text-3xl mb-2 opacity-20">✦</div>
                  <div className="text-sm">有问题，尽管问</div>
                  <div className="text-xs mt-1 text-zinc-700">多模型综合 · 比任何单一 AI 更强</div>
                </div>
              </div>
            )}

            {/* Conversation messages */}
            {current?.messages.map((msg, idx) => (
              <div key={idx}>
                {msg.role === 'user' ? (
                  <div className="flex justify-end pt-4 pb-2">
                    <div className="max-w-[85%] px-3.5 py-2 rounded-2xl bg-surface-3/80 text-zinc-200 text-[13px] leading-relaxed whitespace-pre-wrap">
                      {msg.content}
                    </div>
                  </div>
                ) : msg.response ? (
                  <div className="pt-2 pb-4">
                    <ResponseDisplay
                      response={msg.response}
                      onAction={(action) => handleLowConfidenceAction(action, current.messages[idx - 1]?.content || '')}
                    />
                  </div>
                ) : null}
              </div>
            ))}

            {/* Resolved mode badge (when auto mode was used) */}
            {resolvedMode && !loading && (
              <div className="flex items-center gap-1 text-[10px] text-oracle-500/60 mb-1">
                <span>智能路由 →</span>
                <span className="text-oracle-400">{resolvedMode}</span>
              </div>
            )}

            {/* Error */}
            {error && (
              <div className="mt-2 px-3 py-2 rounded-lg bg-red-500/10 border border-red-500/20 text-red-400 text-xs">
                {error}
              </div>
            )}

            {/* Socratic loading */}
            {isSocraticLoading && (
              <div className="flex items-center gap-2 py-6 text-xs text-zinc-500">
                <div className="w-1.5 h-1.5 rounded-full bg-oracle-500 animate-pulse" />
                正在创建苏格拉底对话...
              </div>
            )}

            {/* Streaming: stage indicator + content */}
            {isStreaming && !isSocraticLoading && (
              <div className="mt-2 pb-4">
                {/* Stage indicator — minimal, inline */}
                <div className="text-[10px] text-zinc-600 flex items-center gap-1.5 mb-1.5">
                  <div className="w-1.5 h-1.5 rounded-full bg-oracle-500 animate-pulse" />
                  <span>{streamStage || "正在连接模型..."}</span>
                  {contributorsDone > 0 && <span className="text-zinc-700">({contributorsDone} 模型已响应)</span>}
                </div>
                {/* Content */}
                {(streamTokens || streamPreview) ? (
                  <div className="prose-oracle">
                    <ReactMarkdown>{streamTokens || streamPreview}</ReactMarkdown>
                    {!streamTokens && streamPreview && (
                      <p className="text-[10px] text-zinc-600 mt-1.5">⏳ 正在综合多模型观点...</p>
                    )}
                    {streamTokens && <span className="inline-block w-1.5 h-3.5 bg-oracle-400/60 animate-pulse ml-0.5" />}
                  </div>
                ) : (
                  <div className="flex items-center gap-2 py-4 text-xs text-zinc-500">
                    <div className="w-1.5 h-1.5 rounded-full bg-oracle-500/50 animate-pulse" />
                    模型思考中...
                  </div>
                )}
              </div>
            )}

            {/* Final response */}
            {response && !loading && (
              <div className="mt-2 pb-4 animate-fade-in">
                <ResponseDisplay response={response} onAction={handleLowConfidenceAction} />
              </div>
            )}

            {/* Clarification needed (preflight) */}
            {clarification && (
              <div className="mt-2 p-3 rounded-lg bg-amber-500/5 border border-amber-500/20 text-xs">
                <p className="text-zinc-300 mb-2">{clarification.message}</p>
                {clarification.suggested_questions.length > 0 && (
                  <div className="flex flex-col gap-1 mt-1">
                    {clarification.suggested_questions.map((q, i) => (
                      <button
                        key={i}
                        onClick={() => { setClarification(null); handleSubmit(q); }}
                        className="text-left px-2 py-1.5 rounded bg-surface-3/50 text-zinc-400 hover:text-zinc-200 hover:bg-surface-4/50 border border-surface-4/30 transition-all"
                      >
                        {q}
                      </button>
                    ))}
                  </div>
                )}
                <button
                  onClick={() => {
                    setClarification(null);
                    const q = lastQuestionRef.current;
                    if (q) runAskStream({ question: q, mode: mode === "auto" ? "auto" : mode, skip_preflight: true, web_search: webSearch, session_id: sessionId || undefined });
                  }}
                  className="mt-1 px-2 py-1 text-zinc-600 hover:text-zinc-400 transition-colors"
                >
                  继续使用原始问题
                </button>
              </div>
            )}

            {/* Companion hint (DepthGate + Coach plan proposal + Coach micro-challenge) */}
            {companionHint && (
              <div className="mt-2 p-2.5 rounded-lg bg-oracle-500/5 border border-oracle-500/20 text-xs">
                {/* Coach plan proposal gets special styling */}
                {companionHint.type === "coach_plan_proposal" && (
                  <div className="flex items-center gap-1 text-oracle-400 text-[10px] mb-1">
                    <CheckCircle size={10} />
                    <span className="font-medium">认知教练建议</span>
                  </div>
                )}
                {companionHint.type === "coach_micro_challenge" && (
                  <div className="flex items-center gap-1 text-oracle-400 text-[10px] mb-1">
                    <span className="font-medium">💡 思维挑战</span>
                  </div>
                )}
                <p className="text-zinc-300 mb-1.5">{companionHint.message}</p>
                <div className="flex flex-wrap gap-1.5">
                  {companionHint.suggestions.map((s) => (
                    <button
                      key={s.mode}
                      onClick={() => handleCoachAction(companionHint.type, s.mode, companionHint.plan_id)}
                      className="px-2 py-1 rounded-full bg-oracle-500/10 text-oracle-400 hover:bg-oracle-500/20 border border-oracle-500/20 transition-all"
                    >
                      {s.label}
                    </button>
                  ))}
                  <button
                    onClick={() => setCompanionHint(null)}
                    className="px-2 py-1 rounded-full text-zinc-600 hover:text-zinc-400 transition-colors"
                  >
                    跳过
                  </button>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* ===== Bottom fixed: input + mode selector ===== */}
      <div className="shrink-0 border-t border-surface-4/20 px-3 sm:px-4 pt-2 pb-3">
        <div className="max-w-3xl mx-auto">
          <QueryInput
            onSubmit={handleSubmit}
            loading={isAnyLoading}
            mode={mode}
            onCancel={isAnyLoading ? cancelRequest : undefined}
          />
          <div className="flex items-center mt-1.5">
            <ModeSelector
              selected={mode}
              onChange={setMode}
              disabled={false}
              webSearch={webSearch}
              onWebSearchChange={setWebSearch}
            />
          </div>
          </div>
        </div>
      </div>
    </div>
  );
}
