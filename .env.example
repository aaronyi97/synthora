# Synthora — API Keys
# Copy this file to .env and fill in your keys
# NEVER commit .env to git

# ============================================================
# Observability
# ============================================================
SENTRY_DSN=

# ============================================================
# OpenAI (OpenAI-compatible endpoint)
# ============================================================
OPENAI_BASE_URL=https://your-openai-endpoint/v1
OPENAI_GPT52_API_KEY=sk-xxx
OPENAI_GPT53_CODEX_API_KEY=sk-xxx

# ============================================================
# Claude (OpenAI-compatible endpoint)
# ============================================================
CLAUDE_BASE_URL=https://your-claude-endpoint/v1
CLAUDE_SONNET_KEY=sk-xxx
CLAUDE_SONNET_THINKING_KEY=sk-xxx
CLAUDE_OPUS_THINKING_KEY=sk-xxx
# ============================================================
# Gemini (multiple providers)
# ============================================================
# Gemini 3 Pro
GEMINI_PRO_API_KEY=ak-xxx
GEMINI_PRO_BASE_URL=https://your-gemini-pro-proxy/v1

# Gemini 3 Pro Thinking
GEMINI_PRO_THINKING_API_KEY=sk-xxx
GEMINI_PRO_THINKING_BASE_URL=https://your-gemini-thinking-proxy/v1

# Gemini 3 Flash
GEMINI_FLASH_API_KEY=sk-xxx
GEMINI_FLASH_BASE_URL=https://your-gemini-flash-proxy/v1

# ============================================================
# Kimi (Moonshot 官方直连)
# ============================================================
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_OFFICIAL_API_KEY_1=sk-xxx
KIMI_OFFICIAL_API_KEY_2=sk-xxx
KIMI_OFFICIAL_API_KEY_3=sk-xxx
KIMI_OFFICIAL_API_KEY_4=sk-xxx

# ============================================================
# DeepSeek (official)
# ============================================================
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ============================================================
# OpenRouter (serves Perplexity sonar / sonar-pro)
# ============================================================
OPENROUTER_API_KEY=sk-or-v1-xxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Optional legacy direct Perplexity key (currently unused by config.yaml)
# PERPLEXITY_API_KEY=pplx-xxx
# PERPLEXITY_BASE_URL=https://api.perplexity.ai

# ============================================================
# Per-model Proxy (optional)
# ============================================================
# Optionally route a specific model's traffic through an HTTP/SOCKS proxy.
# Define any env var below, then set that model's `proxy_env` field in
# config.yaml to the var name. Leave unset for a direct connection.
#
# MODEL_PROXY=http://user:pass@host:port

# ============================================================
# Auth
# ============================================================
ADMIN_PASSWORD=your-admin-password-here
AUTH_PASSWORD=your-password-here
SESSION_SECRET=random-secret-string-here

# ============================================================
# Search (Tavily — search provider API key)
# ============================================================
TAVILY_API_KEY=tvly-xxx

# ============================================================
# SMS (Aliyun Dysmsapi)
# ============================================================
ALIYUN_ACCESS_KEY_ID=LTAIxxxxxxxx
ALIYUN_ACCESS_KEY_SECRET=xxxxxxxx
ALIYUN_SMS_SIGN_NAME=Synthora
ALIYUN_SMS_TEMPLATE_CODE=SMS_123456789

# ============================================================
# API Security & Middleware
# ============================================================
# CORS origins (comma-separated). Default: * (allow all)
# Production example: CORS_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=*

# Rate limiting (default: 30 RPM, 5 concurrent)
# Set RATE_LIMIT_ENABLED=0 to disable
RATE_LIMIT_RPM=30
RATE_LIMIT_MAX_CONCURRENT=5
RATE_LIMIT_ENABLED=1

# Audit logging (default: enabled, writes to data/logs/audit.jsonl)
# Set AUDIT_LOG_ENABLED=0 to disable
AUDIT_LOG_ENABLED=1
# AUDIT_LOG_PATH=data/logs/audit.jsonl

# ============================================================
# Query Monitor (Layer 2 异步评估)
# ============================================================
# Layer 2 抽样率 (0.0-1.0)。默认 0.3 (30%)。
# 重大聚合策略变更后临时提升至 0.8，2周后回调至 0.3。
MONITOR_SAMPLE_RATE=0.3
# Layer 2 评估模型。默认 gpt52（与 Extractor/Sonnet 不同家族，交叉验证）
MONITOR_EVALUATOR_MODEL=gpt52

# ============================================================
# GitHub (for gh CLI — optional)
# ============================================================
# GH_TOKEN=ghp_xxx
